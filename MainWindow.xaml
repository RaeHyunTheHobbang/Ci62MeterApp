<Window x:Class="MeterCi62App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MeterCi62App.ViewModel"
    mc:Ignorable="d"
    Title="MeterMiddler" Height="200" Width="400" ResizeMode="NoResize" 
    Background="#AAA" FontFamily="Segoe UI, Malgun Gothic">
    <Window.Resources>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </Window.Resources>
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="2*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.Column="2" x:Name="BtnGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <!-- Setting: 도착 URL 입력 가능 -->
            <Button Grid.Column="0" x:Name="settingBtn" Background="White"  HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30"
                    Command="{Binding viewBtnCtrl}" CommandParameter="Setting">
                <Image Source="{Binding settingBtnSrc}"></Image>
            </Button>
            <!-- Exit Button: 앱종료 버튼 , x의 경우 옆에 Hide-->
            <Button Grid.Column="1" x:Name="exitBtn"   Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30"
                    Command="{Binding viewBtnCtrl}" CommandParameter="CloseAll">
                <Image Source="{Binding exitBtnSrc}" Stretch="Fill"></Image>
            </Button>
        </Grid>
        
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="4*"></ColumnDefinition>

            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="2*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>

            <Border Grid.Row="1" Grid.Column="0" Background="{Binding IsConnect, Converter={StaticResource BoolToColorConverter}}"
                    BorderBrush="Gray" BorderThickness="1" Width="30" Height="30">
            </Border>
            
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="onOffStateBlock" Text="{Binding onOffInfoText}" HorizontalAlignment="Center"
                       VerticalAlignment="Center" FontSize="20"></TextBlock>

        </Grid>
        
    </Grid>
   
    
</Window>
