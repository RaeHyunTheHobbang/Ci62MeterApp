<Window x:Class="MeterCi62App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MeterCi62App"
    mc:Ignorable="d"
    Title="MeterCi62App" Height="200" Width="400" ResizeMode="NoResize" 
    Background="#F1F5F9" FontFamily="Segoe UI, Malgun Gothic">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="2*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="2*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.Column="2" x:Name="BtnGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="settingBtn" Background="White"  HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30">
                <Image Source="{Binding settingBtnSrc}"></Image>
            </Button>
            <Button Grid.Column="1" x:Name="exitBtn"   Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30">
                <Image Source="{Binding exitBtnSrc}" ></Image>
            </Button>
        </Grid>
        
    </Grid>
   
    
</Window>
